+++ b/consulting/energy-tourism-offer.html
@@ -25,6 +25,8 @@
 
   * { margin: 0; padding: 0; box-sizing: border-box; }
 
+  html, body { overflow-x: hidden; }
+
   body {
     background: var(--bg);
     color: var(--text);
@@ -569,7 +571,9 @@
 
     /* Topbar */
     .topbar { padding: 0 16px; gap: 6px; font-size: 11px; }
+    .topbar .breadcrumb span:not(.current) { display: none; }
     .topbar-actions { gap: 6px; }
